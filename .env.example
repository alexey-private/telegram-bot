# Telegram bot token from BotFather
BOT_TOKEN=your_bot_token_here

# Postgres connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://botuser:botpass@localhost:5432/botdb

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use for AI feature (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max conversation turns kept in session before oldest are trimmed
AI_MAX_HISTORY_MESSAGES=20

# Redis connection string for persistent session storage
REDIS_URL=redis://localhost:6379

# HTTP port for NestJS (not required for polling-only bots, kept for future webhook use)
PORT=3000
